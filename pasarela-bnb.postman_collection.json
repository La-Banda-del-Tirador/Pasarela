              "status": "Created",
              "code": 201,
              "body": "{\n  \"paymentId\": \"a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4\",\n  \"payUrl\": \"http://localhost:9191/pay/a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4\",\n  \"qrId\": \"187388\",\n  \"qrImage\": \"iVBORw0KGgoAAAANSUhEUgAA...\",\n  \"amount\": 75,\n  \"currency\": \"BOB\",\n  \"description\": \"Almuerzo Mesa 5\",\n  \"status\": \"pending\",\n  \"expiresAt\": \"2026-12-31\",\n  \"callbackUrl\": \"http://localhost:9292/gracias?order=REST-2026-001\"\n}"
